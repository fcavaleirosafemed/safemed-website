# Database
DATABASE_URI=postgresql://user:password@localhost:5432/safemed

# Payload
PAYLOAD_SECRET=your-secret-key-here-change-in-production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Mivo Integration
NEXT_PUBLIC_MIVO_API_URL=https://mivo.safemed.solutions/api
MIVO_API_KEY=your-mivo-api-key

# AI Chat Configuration
# Provider: anthropic | openai
AI_PROVIDER=anthropic
# Model: claude-haiku-4-20250414 (cheapest ~$0.001/req) | claude-sonnet-4-20250514 | gpt-4o-mini
AI_MODEL=claude-haiku-4-20250414
# Daily request limit (200 requests * ~$0.001 = ~$0.20/day max)
AI_DAILY_LIMIT=200
# API Keys — get yours at:
# Anthropic: https://console.anthropic.com/settings/keys
# OpenAI: https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
